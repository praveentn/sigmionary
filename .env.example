# Copy this file to .env and fill in your values.
DISCORD_TOKEN=your_bot_token_here

# PostgreSQL connection string (required — provided automatically by Railway)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/sigmionary

# Optional: set to your test server ID for instant slash-command registration during dev.
# Remove or leave blank for global (production) registration.
DISCORD_GUILD_ID=

# HTTP status server port (default: 8080)
PORT=8080

# Railway Volume mount path for puzzle images (default: /sigmionary/images)
# On Railway: set to /sigmionary/images (mount the volume at /sigmionary)
# For local dev: set to any local directory, e.g. /tmp/sigmionary-images
IMAGES_PATH=/sigmionary/images

# Comma-separated Discord user IDs allowed to use developer commands (e.g. !addpuzzle)
# Find your ID: Discord → Settings → Advanced → Developer Mode → right-click your name → Copy ID
DEVELOPER_IDS=

# ── External leaderboard integrations ─────────────────────────────────────────
# Comma-separated list of service names to configure.
# For each NAME in this list, define NAME_ENABLED, NAME_URL, NAME_API_KEY, NAME_GUILDS.
EXTERNAL_LEADERBOARDS=SIGMAFEUD,NAVI

# SIGMAFEUD service
SIGMAFEUD_ENABLED=true
SIGMAFEUD_URL=https://sigmafeud-production.up.railway.app
SIGMAFEUD_API_KEY=your_sigmafeud_key_here
# Optional: restrict to specific guild IDs (comma-separated). Leave blank for all guilds.
SIGMAFEUD_GUILDS=

# NAVI service
NAVI_ENABLED=false
NAVI_URL=https://navi-api.example.com
NAVI_API_KEY=your_navi_key_here
# Optional: restrict to specific guild IDs (comma-separated). Leave blank for all guilds.
NAVI_GUILDS=
